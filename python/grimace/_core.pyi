    @property
    def root_idx(self) -> int: ...

    def initial_state(self) -> RootedConnectedNonStereoWalkerState: ...
    def next_token_support(
        self,
        state: RootedConnectedNonStereoWalkerState,
        /,
    ) -> list[str]: ...
    def next_choice_texts(
        self,
        state: RootedConnectedNonStereoWalkerState,
        /,
    ) -> list[str]: ...
    def advance_token(
        self,
        state: RootedConnectedNonStereoWalkerState,
        chosen_token: str,
        /,
    ) -> RootedConnectedNonStereoWalkerState: ...
    def advance_choice(
        self,
        state: RootedConnectedNonStereoWalkerState,
        chosen_idx: int,
        /,
    ) -> RootedConnectedNonStereoWalkerState: ...
    def is_terminal(self, state: RootedConnectedNonStereoWalkerState, /) -> bool: ...
    def enumerate_support(self) -> list[str]: ...


class RootedConnectedNonStereoDecoder:
    def __init__(self, graph: object, root_idx: int, /) -> None: ...
    def cache_key(self) -> str: ...
    def next_token_support(self) -> list[str]: ...
