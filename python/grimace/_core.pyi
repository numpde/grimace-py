from typing import Any


class PreparedSmilesGraph:
    def __init__(self, data: object, /) -> None: ...

    @property
    def schema_version(self) -> int: ...

    @property
    def surface_kind(self) -> str: ...

    @property
    def policy_name(self) -> str: ...

    @property
    def policy_digest(self) -> str: ...

    @property
    def rdkit_version(self) -> str: ...

    @property
    def identity_smiles(self) -> str: ...

    @property
    def atom_count(self) -> int: ...

    @property
    def bond_count(self) -> int: ...

    @property
    def atom_tokens(self) -> list[str]: ...

    @property
    def bond_dirs(self) -> list[str]: ...

    def neighbors_of(self, atom_idx: int, /) -> list[int]: ...
    def bond_token(self, begin_idx: int, end_idx: int, /) -> str: ...
    def matches_writer_flags(
        self,
        *,
        isomeric_smiles: bool,
        kekule_smiles: bool,
        all_bonds_explicit: bool,
        all_hs_explicit: bool,
        ignore_atom_map_numbers: bool,
    ) -> bool: ...
    def token_inventory_superset(self, root_idx: int, /) -> list[str]: ...
    def validate_policy(self, policy_name: str, policy_digest: str, /) -> None: ...
    def enumerate_rooted_connected_nonstereo_support(self, root_idx: int, /) -> list[str]: ...
    def enumerate_rooted_connected_stereo_support(self, root_idx: int, /) -> list[str]: ...
    def to_dict(self) -> dict[str, Any]: ...


class PreparedMol:
    @staticmethod
    def from_bytes(data: bytes, /) -> "PreparedMol": ...

    def to_bytes(self) -> bytes: ...
    def matches_writer_flags(
        self,
        *,
        isomeric_smiles: bool,
        kekule_smiles: bool,
        all_bonds_explicit: bool,
        all_hs_explicit: bool,
        ignore_atom_map_numbers: bool,
    ) -> bool: ...
    def fragment_count(self) -> int: ...
    def atom_count(self) -> int: ...
    def rooted_fragments(
        self,
        rooted_at_atom: int | None,
        /,
    ) -> list[tuple[PreparedSmilesGraph, int | None]]: ...


class _SplitMix64Sampler:
    def __init__(self, seed: int, /) -> None: ...
    def uniform_index(self, len: int, /) -> int: ...
    def weighted_index(self, weights: list[int], /) -> int: ...


