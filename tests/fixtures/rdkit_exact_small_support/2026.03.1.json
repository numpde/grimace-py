{
  "rdkit_version": "2026.03.1",
  "cases": [
    {
      "id": "cco_root1_nonstereo",
      "smiles": "CCO",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "expected": ["C(C)O", "C(O)C"],
      "expected_inventory": ["(", ")", "C", "O"]
    },
    {
      "id": "na_cyanide_root0_disconnected",
      "smiles": "[Na+].C#N",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "expected": ["[Na+].C#N", "[Na+].N#C"],
      "expected_inventory": ["#", ".", "C", "N", "[Na+]"]
    },
    {
      "id": "co_cco_root0_disconnected",
      "smiles": "CO.CCO",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "expected": ["CO.C(C)O", "CO.C(O)C", "CO.CCO", "CO.OCC"],
      "expected_inventory": ["(", ")", ".", "C", "O"]
    },
    {
      "id": "co_cco_root2_disconnected",
      "smiles": "CO.CCO",
      "rooted_at_atom": 2,
      "isomeric_smiles": false,
      "expected": ["CO.CCO", "OC.CCO"],
      "expected_inventory": [".", "C", "O"]
    },
    {
      "id": "pyridine_root1_nonstereo",
      "smiles": "c1ccncc1",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "expected": ["c1cccnc1", "c1cnccc1"],
      "expected_inventory": ["1", "c", "n"]
    },
    {
      "id": "pyridine_root0_kekule",
      "smiles": "c1ccncc1",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "kekule_smiles": true,
      "expected": ["C1=CC=NC=C1", "C1C=CN=CC=1"],
      "expected_inventory": ["1", "=", "C", "N"]
    },
    {
      "id": "benzene_root0_all_bonds_explicit",
      "smiles": "c1ccccc1",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "all_bonds_explicit": true,
      "expected": ["c1:c:c:c:c:c:1"],
      "expected_inventory": ["1", ":", "c"]
    },
    {
      "id": "acetonitrile_root1_nonstereo",
      "smiles": "CC#N",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "expected": ["C(#N)C", "C(C)#N"],
      "expected_inventory": ["#", "(", ")", "C", "N"]
    },
    {
      "id": "acetonitrile_root1_all_bonds_explicit",
      "smiles": "CC#N",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "all_bonds_explicit": true,
      "expected": ["C(#N)-C", "C(-C)#N"],
      "expected_inventory": ["#", "(", ")", "-", "C", "N"]
    },
    {
      "id": "fluorochloroethene_root1_stereo",
      "smiles": "F/C=C\\Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "expected": ["C(/F)=C/Cl", "C(=C/Cl)/F"],
      "expected_inventory": ["(", ")", "/", "=", "C", "Cl", "F"]
    },
    {
      "id": "fluorochloroethene_root1_explicit_bonds",
      "smiles": "F/C=C\\Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "all_bonds_explicit": true,
      "expected": ["C(/F)=C/Cl", "C(=C/Cl)/F"],
      "expected_inventory": ["(", ")", "/", "=", "C", "Cl", "F"]
    },
    {
      "id": "fluorochloroethene_root1_all_hs_explicit",
      "smiles": "F/C=C/Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "all_hs_explicit": true,
      "expected": ["[CH](/[F])=[CH]\\[Cl]", "[CH](=[CH]\\[Cl])/[F]"],
      "expected_inventory": ["(", ")", "/", "=", "[CH]", "[Cl]", "[F]", "\\"]
    },
    {
      "id": "methylchloroethene_root1_nonstereo",
      "smiles": "C/C=C\\Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "expected": ["C(=CCl)C", "C(C)=CCl"],
      "expected_inventory": ["(", ")", "=", "C", "Cl"]
    },
    {
      "id": "methylchloroethene_root1_stereo",
      "smiles": "C/C=C\\Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "expected": ["C(/C)=C/Cl", "C(=C/Cl)/C"],
      "expected_inventory": ["(", ")", "/", "=", "C", "Cl"]
    },
    {
      "id": "fluorochloroimine_root1_stereo",
      "smiles": "F/C=N/Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "expected": ["C(/F)=N\\Cl", "C(=N\\Cl)/F"],
      "expected_inventory": ["(", ")", "/", "=", "C", "Cl", "F", "N", "\\"]
    },
    {
      "id": "fluorochloroimine_root1_all_hs_explicit",
      "smiles": "F/C=N/Cl",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "all_hs_explicit": true,
      "expected": ["[CH](/[F])=[N]\\[Cl]", "[CH](=[N]\\[Cl])/[F]"],
      "expected_inventory": ["(", ")", "/", "=", "[CH]", "[Cl]", "[F]", "[N]", "\\"]
    },
    {
      "id": "bromochlorofluoromethane_root0_nonstereo",
      "smiles": "F[C@H](Cl)Br",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "expected": ["FC(Br)Cl", "FC(Cl)Br"],
      "expected_inventory": ["(", ")", "Br", "C", "Cl", "F"]
    },
    {
      "id": "bromochlorofluoromethane_root1_stereo",
      "smiles": "F[C@H](Cl)Br",
      "rooted_at_atom": 1,
      "isomeric_smiles": true,
      "expected": [
        "[C@@H](Br)(F)Cl",
        "[C@@H](Cl)(Br)F",
        "[C@@H](F)(Cl)Br",
        "[C@H](Br)(Cl)F",
        "[C@H](Cl)(F)Br",
        "[C@H](F)(Br)Cl"
      ],
      "expected_inventory": ["(", ")", "Br", "Cl", "F", "[C@@H]", "[C@H]"]
    },
    {
      "id": "bromochlorofluoromethane_root2_stereo",
      "smiles": "F[C@H](Cl)Br",
      "rooted_at_atom": 2,
      "isomeric_smiles": true,
      "expected": ["Cl[C@@H](F)Br", "Cl[C@H](Br)F"],
      "expected_inventory": ["(", ")", "Br", "Cl", "F", "[C@@H]", "[C@H]"]
    },
    {
      "id": "ammine_copper_root1_dative",
      "smiles": "[NH3][Cu]",
      "rooted_at_atom": 1,
      "isomeric_smiles": false,
      "expected": ["[Cu]<-[NH3]"],
      "expected_inventory": ["<-", "[Cu]", "[NH3]"]
    },
    {
      "id": "ammine_copper_root0_dative",
      "smiles": "[NH3][Cu]",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "expected": ["[NH3]->[Cu]"],
      "expected_inventory": ["->", "[Cu]", "[NH3]"]
    },
    {
      "id": "ethyl_atom_maps_ignored",
      "smiles": "[CH3:7]C",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "ignore_atom_map_numbers": true,
      "expected": ["CC"],
      "expected_inventory": ["C"]
    },
    {
      "id": "ethyl_atom_maps_kept",
      "smiles": "[CH3:7]C",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "ignore_atom_map_numbers": false,
      "expected": ["[CH3:7]C"],
      "expected_inventory": ["C", "[CH3:7]"]
    },
    {
      "id": "methane_all_hs_explicit",
      "smiles": "C",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "all_hs_explicit": true,
      "expected": ["[CH4]"],
      "expected_inventory": ["[CH4]"]
    }
  ]
}
