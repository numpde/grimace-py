      "source": "RDKit Code/GraphMol/SmilesParse/catch_tests.cpp:atoms bound to metals should always have Hs specified",
      "smiles": "Cl[Pt](F)([NH2])[OH]",
      "rooted_at_atom": 0,
      "isomeric_smiles": false,
      "expected_inventory": [
        "(",
        ")",
        "[Cl]",
        "[F]",
        "[NH2]",
        "[OH]",
        "[Pt]"
      ],
      "expected": [
        "[Cl][Pt]([F])([NH2])[OH]",
        "[Cl][Pt]([F])([OH])[NH2]",
        "[Cl][Pt]([NH2])([F])[OH]",
        "[Cl][Pt]([NH2])([OH])[F]",
        "[Cl][Pt]([OH])([F])[NH2]",
        "[Cl][Pt]([OH])([NH2])[F]"
      ]
    },
